rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Global Helpers
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isWhitelisted() {
      return isVerified() && exists(/databases/$(database)/documents/authorized_users/$(request.auth.token.email));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    match /test/connection {
      allow read: if true;
    }

    match /authorized_users/{email} {
      // Users can check their own status
      allow get: if isSignedIn() && request.auth.token.email == email;
      // Writing to this list should be restricted (manual via console or admin only)
      allow read, write: if false; 
    }

    // ===============================================================
    // Collection: sessions
    // ===============================================================
    function isValidSession(data) {
      return data.keys().hasAll(['id', 'locality', 'date', 'sampleMode', 'items', 'results', 'completed', 'userId']) &&
             data.keys().size() >= 8 &&
             data.id is string && data.id.size() <= 128 &&
             data.locality is string && data.locality.size() <= 500 &&
             data.date is string &&
             data.sampleMode in ['aleatoria', 'sistematica', 'manual', 'completo'] &&
             data.items is list && data.items.size() <= 2000 &&
             data.results is map &&
             data.completed is bool &&
             data.userId == request.auth.uid;
    }

    match /sessions/{sessionId} {
      // Visitors can only read
      allow list, get: if true;

      // Only whitelisted users can create/edit/delete
      allow create: if isWhitelisted() && isValidId(sessionId) && isValidSession(incoming()) && incoming().id == sessionId;
      
      allow update: if isWhitelisted() && isValidId(sessionId) &&
                      incoming().userId == existing().userId && 
                      incoming().userId == request.auth.uid &&
                      (
                        (incoming().diff(existing()).affectedKeys().hasOnly(['completed', 'results', 'updatedAt', 'items'])) ||
                        (incoming().diff(existing()).affectedKeys().hasOnly(['locality', 'date', 'sampleMode', 'updatedAt', 'items']))
                      );

      allow delete: if isWhitelisted() && existing().userId == request.auth.uid;
    }

    // ===============================================================
    // Collection: actions
    // ===============================================================
    function isValidAction(data) {
      return data.keys().hasAll(['id', 'sessionId', 'patrimony', 'description', 'locality', 'date', 'resolved', 'userId']) &&
             data.id is string && data.id.size() <= 128 &&
             data.sessionId is string && data.sessionId.size() <= 128 &&
             data.patrimony is string && data.patrimony.size() <= 100 &&
             data.description is string && data.description.size() <= 2000 &&
             data.locality is string && data.locality.size() <= 500 &&
             data.date is string &&
             data.resolved is bool &&
             data.userId == request.auth.uid;
    }

    match /actions/{actionId} {
      // Visitors can only read
      allow list, get: if true;

      // Only whitelisted users can create/edit/delete
      allow create: if isWhitelisted() && isValidId(actionId) && isValidAction(incoming()) && incoming().id == actionId &&
                      exists(/databases/$(database)/documents/sessions/$(incoming().sessionId)); 

      allow update: if isWhitelisted() && isValidId(actionId) &&
                      incoming().userId == existing().userId && 
                      incoming().userId == request.auth.uid &&
                      (
                        (incoming().diff(existing()).affectedKeys().hasOnly(['resolved', 'resolutionDate', 'updatedAt'])) ||
                        (incoming().diff(existing()).affectedKeys().hasOnly(['description', 'updatedAt']))
                      );

      allow delete: if isWhitelisted() && existing().userId == request.auth.uid;
    }
  }
}
